<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:gravity="center"
    android:tag="moreOfferItemView"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/mbridge_reward_end_card_item_iv"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginLeft="5dp"
        android:layout_marginRight="5dp"
        app:mbridge_data="data=$listData.creative_info.icon_url|radius=6" />

    <TextView
        android:id="@+id/mbridge_reward_end_card_item_title_tv"
        android:layout_width="60dp"
        android:layout_height="15dp"
        android:layout_marginLeft="5dp"
        android:layout_marginRight="5dp"
        android:layout_marginTop="2dp"
        android:layout_below="@+id/mbridge_reward_end_card_item_iv"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:padding="2dp"
        android:textColor="@color/mbridge_black"
        android:textSize="9sp"
        app:mbridge_data="data=$listData.creative_info.title" />
</LinearLayout>