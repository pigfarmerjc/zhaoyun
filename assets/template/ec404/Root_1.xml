<?xml version="1.0" encoding="utf-8"?>
<com.mbridge.msdk.config.dynamic.baseview.cusview.XMLView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:tag="ecFullScreenBtn"
        app:mbridge_data="clickable=true"/>

    <RelativeLayout
        android:id="@+id/mbridge_native_ec_rl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignBottom="@+id/mbridge_iv_icon"
        android:layout_alignParentTop="true"
        android:layout_marginBottom="35dp">

        <ImageView
            android:id="@+id/mbridge_iv_adbanner_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitXY"
            app:mbridge_data="data=$g0.showModel.currentOffer.creative_info.image_url|effect=blur" />

        <ImageView
            android:id="@+id/mbridge_iv_adbanner"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_centerInParent="true"
            android:layout_margin="5dp"
            android:tag="bigImage"
            app:mbridge_data="data=$g0.showModel.currentOffer.creative_info.image_url|effect=corner|radius=15|clickable=true" />

        <TextView
            android:id="@+id/mbridge_tv_flag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignParentRight="true"
            android:layout_alignParentBottom="true"
            android:background="@color/mbridge_color_999999"
            android:gravity="center"
            android:paddingLeft="3dp"
            android:paddingRight="3dp"
            android:text="AD"
            android:textSize="11sp"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/mbridge_iv_flag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignParentRight="true"
            android:layout_alignParentBottom="true" />
    </RelativeLayout>

    <ImageView
        android:id="@+id/mbridge_iv_icon"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_above="@+id/mbridge_local_tag"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="40dp"
        android:scaleType="centerCrop"
        android:tag="icon"
        app:mbridge_data="data=$g0.showModel.currentOffer.creative_info.icon_url|effect=corner|radius=10|clickable=true" />

    <RelativeLayout
        android:id="@+id/mbridge_local_tag"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:layout_centerInParent="true" />

    <TextView
        android:id="@+id/mbridge_tv_apptitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/mbridge_iv_icon"
        android:layout_marginTop="10dp"
        android:ellipsize="end"
        android:gravity="center_horizontal"
        android:singleLine="true"
        android:textColor="#FF000000"
        android:textSize="22sp"
        android:textStyle="bold"
        app:mbridge_data="data=$g0.showModel.currentOffer.creative_info.title" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/mbridge_tv_apptitle"
        android:gravity="center"
        android:orientation="vertical">

        <com.mbridge.msdk.config.dynamic.baseview.cusview.StarLevelLayoutView
            android:id="@+id/mbridge_sv_starlevel"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:gravity="center"
            app:mbridge_data="data=$g0.showModel.currentOffer.creative_info.rating" />

        <com.mbridge.msdk.config.dynamic.baseview.cusview.HeatLevelLayoutView
            android:id="@+id/mbridge_sv_heat_count_level"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_marginTop="2dp"
            android:gravity="center"
            app:mbridge_data="data=$g0.showModel.currentOffer.creative_info.number_rating" />
    </LinearLayout>

    <RelativeLayout
        android:id="@+id/mbridge_ec_cta"
        android:layout_width="200dp"
        android:layout_height="50dp"
        android:layout_marginBottom="60dp"
        android:layout_above="@+id/mbridge_iv_logo"
        android:tag="ctaBtn"
        android:layout_centerHorizontal="true"
        app:mbridge_data="clickable=true">

        <ProgressBar
            android:id="@+id/mbridge_download_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:progress="0"
            android:progressDrawable="@drawable/mbridge_cm_progress_drawable"
            app:mbridge_data="data=$progressbar.event.downloadProgress" />

        <TextView
            android:id="@+id/mbridge_tv_cta"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_centerHorizontal="true"
            android:ellipsize="end"
            android:gravity="center"
            android:lines="1"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            app:mbridge_data="data=$g0.showModel.currentOffer.creative_info.ctatext" />

    </RelativeLayout>

    <ImageView
        android:id="@+id/mbridge_iv_logo"
        android:layout_width="50dp"
        android:layout_height="18dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_margin="10dp"
        android:src="@drawable/mbridge_reward_end_pager_logo" />

    <com.mbridge.msdk.config.dynamic.baseview.cusview.BaitClickView
        android:id="@+id/mbridge_animation_click_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:tag="baitClickView" />

    <RelativeLayout
        android:id="@+id/mbridge_native_ec_controller"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/mbridge_iv_link"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="20dp"
            android:layout_marginRight="10dp"
            android:layout_marginBottom="10dp"
            android:src="@drawable/mbridge_reward_notice"
            android:tag="privacyBtn"
            app:mbridge_data="clickable=true" />

        <ImageView
            android:id="@+id/mbridge_iv_close"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentRight="true"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="20dp"
            android:layout_marginRight="10dp"
            android:layout_marginBottom="10dp"
            android:contentDescription="closeButton"
            android:src="@drawable/mbridge_reward_close"
            android:tag="ecCloseBtn"
            app:mbridge_data="clickable=true" />
    </RelativeLayout>

    <!-- FEEDBACK ALERT -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        android:tag="feedbackAlert">

        <LinearLayout
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/mbridge_cm_feedback_dialog_view_bg"
            android:minHeight="280dp"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <TextView
                    android:id="@+id/mbridge_video_common_alertview_titleview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_centerInParent="true"
                    android:gravity="center"
                    android:singleLine="true"
                    android:text="@string/mbridge_cm_feedback_dialog_title"
                    android:textAllCaps="false"
                    android:textColor="@color/mbridge_black"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/mbridge_video_common_alertview_confirm_button"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"
                    android:gravity="center"
                    android:text="×"
                    android:textColor="@color/mbridge_black"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:tag="feedbackCloseBtn"
                    app:mbridge_data="clickable=true"/>
            </RelativeLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0" />

            <ScrollView
                android:id="@+id/mbridge_video_common_alertview_contentview_scrollview"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:fadeScrollbars="false"
                android:fillViewport="true"
                android:paddingStart="20dp"
                android:paddingTop="16dp"
                android:paddingEnd="20dp"
                android:paddingBottom="16dp"
                android:scrollbars="vertical">

                <com.mbridge.msdk.config.dynamic.baseview.cusview.FeedBackLinerLayout
                    android:id="@+id/mbridge_video_common_alertview_contentview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="160dp"
                    android:orientation="vertical"
                    android:tag="feedbackList"
                    app:mbridge_save_data="data=$g0.showModel.feedback|saveContent=true" />
            </ScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="16dp"
                android:paddingEnd="20dp"
                android:paddingBottom="20dp">

                <TextView
                    android:id="@+id/mbridge_video_common_alertview_cancel_button"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/mbridge_cm_feedback_choice_btn_bg_pressed"
                    android:elevation="2dp"
                    android:gravity="center"
                    android:text="@string/mbridge_cm_feedback_dialog_close_submit"
                    android:textAllCaps="false"
                    android:textColor="@color/mbridge_white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:tag="feedbackSubmitBtn"
                    app:mbridge_data="clickable=true" />

                <TextView
                    android:id="@+id/mbridge_video_common_alertview_private_action_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:minHeight="30dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="@string/mbridge_cm_feedback_dialog_privacy_des"
                    android:textAllCaps="false"
                    android:textColor="@color/mbridge_cm_feedback_dialog_chice_bg_pressed"
                    android:textSize="12sp"
                    android:tag="privacyPolicyBtn"
                    app:mbridge_data="clickable=true"/>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- MORE OFFER -->
    <RelativeLayout
        android:id="@+id/mbridge_reward_end_card_more_offer_rl"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_gravity="center"
        android:layout_alignParentBottom="true"
        android:visibility="gone"
        android:tag="moreOffer"
        android:background="#FFFFFF">

        <com.mbridge.msdk.config.dynamic.baseview.cusview.MoreOfferContainerView
            android:id="@+id/mbridge_moreoffer_hls"
            android:layout_width="200dp"
            android:layout_height="match_parent"
            android:layout_centerVertical="true"
            android:layout_toRightOf="@+id/mbridge_reward_end_card_like_tv"
            android:layout_alignParentRight="true"
            android:scrollbars="none"
            android:tag="moreOfferListView"
            app:mbridge_data ="data=$context.state.moreOfferAdModel.ads|parentPath=$g0.showModel.currentOffer.creative_info.endcard_url|itemXml=more_offer_item" />

        <TextView
            android:id="@+id/mbridge_reward_end_card_like_tv"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:background="@drawable/mbridge_reward_shape_mf_selector"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:textSize="9sp"
            android:gravity="center"
            android:text="Just&#xA;For&#xA;U"
            android:visibility="visible" />
    </RelativeLayout>

    <!--watermark-->
    <ImageView
        android:id="@+id/mbridge_iv_watermark"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:tag="watermark"
        app:mbridge_data="data=$g0.initModel.watermark" />
</com.mbridge.msdk.config.dynamic.baseview.cusview.XMLView>